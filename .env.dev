# Predefined values to get sail up and running immediately

APP_NAME="Local Development"
APP_ENV=development
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

API_STANDARDS_TREE=vnd
API_SUBTYPE=cp
API_PREFIX=api
API_VERSION=v1
API_NAME="API"
API_DEFAULT_FORMAT=json

PROVIDER=ldap
ACCOUNTMANAGER_DRIVER=ldap

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=kcp-mysql-1
DB_PORT=3306
DB_DATABASE=cptest
DB_USERNAME=test
DB_PASSWORD=password

LDAP_DOMAIN="local.dev"
LDAP_BASE_DN="dc=local,dc=dev"
LDAP_LOGGING=true
LDAP_CONNECTION=default
LDAP_HOST=kcp-openldap-1
LDAP_USERNAME="cn=admin,dc=local,dc=dev"
LDAP_PASSWORD=ldappassword
LDAP_PORT=389
LDAP_TIMEOUT=5
LDAP_SSL=false
LDAP_TLS=false
LDAP_OPT_PROTOCOL_VERSION=3
LDAP_ACCESS_GROUPS="cn=admin,ou=controlPanelAccess,o=server,dc=local,dc=dev|cn=orgAdmin,ou=controlPanelAccess,o=server,dc=local,dc=dev"
LDAP_USER_OBJECT_CLASSES=

STRIPE_KEY=
STRIPE_SECRET=
