{
    "require": {
        "php": "^8.4",
        "api-ecosystem-for-laravel/dingo-api": "^4.2.0",
        "asm89/stack-cors": "^2.0",
        "directorytree/ldaprecord": "^3.3.0",
        "directorytree/ldaprecord-laravel": "^3.1.2",
        "doctrine/dbal": "^4.4.3",
        "firebase/php-jwt": "^7.0",
        "guzzlehttp/guzzle": "^7.3",
        "inertiajs/inertia-laravel": "^2.0",
        "laravel/cashier": "^15.4",
        "laravel/framework": "^11.26",
        "laravel/socialite": "^5.16",
        "laravel/tinker": "^2.10",
        "laravel/ui": "^4.0",
        "nwidart/laravel-modules": "^11.1",
        "socialiteproviders/manager": "^4.9",
        "spatie/laravel-backup": "^9.2",
        "spatie/laravel-permission": "^6.9",
        "spatie/laravel-uptime-monitor": "^4.5",
        "tightenco/ziggy": "^2.3",
        "unisharp/laravel-filemanager": "^2.12"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.14",
        "dompdf/dompdf": "^3.0.0",
        "fakerphp/faker": "^1.24",
        "laracasts/cypress": "^3.0",
        "laravel/breeze": "^2.0",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.52",
        "laravel/telescope": "^5.17",
        "mockery/mockery": "^1.3.1",
        "nunomaduro/collision": "^8.3",
        "pestphp/pest": "^2.0",
        "spatie/laravel-ignition": "^2.0"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": false,
            "pestphp/pest-plugin": true,
            "wikimedia/composer-merge-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "laravel/telescope"
            ]
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Modules\\": "modules/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "test": "vendor/bin/pest"
    }
}
